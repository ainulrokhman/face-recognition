# ==============================================================================
# Face Recognition Backend API - Environment Configurations Template
# Copy this file to '.env' and fill in your production credentials.
# ==============================================================================

# 1. API Security Key (X-API-Key)
# Restricts access to Flask endpoints (/api/detect, /api/register, /api/recognize, /api/delete).
# Leave empty in development to disable verification. Require a strong token in production.
# Example: FACE_API_KEY=d7b5f928e36124501aef3f4869c0d164
FACE_API_KEY=your-production-secret-api-key-here

# 2. CORS Allowed Origin
# Restricts cross-origin requests to your frontend web server domain.
# Set to * in development, or set to your CodeIgniter 3 domain in production.
# Example: ALLOWED_ORIGIN=https://absensi.sekolah.sch.id
ALLOWED_ORIGIN=*
